default_platform(:ios)

def load_api_key
  api_key_path = File.join(__dir__, "asc_api_key.json")
  api_key_data = JSON.parse(File.read(api_key_path))
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"] || api_key_data["key_id"],
    issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] || api_key_data["issuer_id"],
    key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"] || api_key_data["key"],
    in_house: false
  )
end

def setup_signing(api_key)
  get_certificates(api_key: api_key, platform: "ios")
  get_provisioning_profile(api_key: api_key, app_identifier: "com.bnjdpn.petitesgouttes", platform: "ios")
  cert_path = lane_context[SharedValues::CERT_FILE_PATH]
  @cert_sha1 = `openssl x509 -inform DER -in "#{cert_path}" -fingerprint -sha1 -noout 2>/dev/null`.strip.split("=").last.gsub(":", "")
  update_code_signing_settings(
    use_automatic_signing: false,
    path: "PetitesGouttes.xcodeproj",
    team_id: "767SX34A7Z",
    bundle_identifier: "com.bnjdpn.petitesgouttes",
    profile_name: lane_context[SharedValues::SIGH_NAME],
    code_sign_identity: @cert_sha1
  )
end

def build_signed_app
  build_app(
    scheme: "PetitesGouttes",
    configuration: "Release",
    export_method: "app-store",
    export_options: {
      signingStyle: "manual",
      teamID: "767SX34A7Z",
      signingCertificate: @cert_sha1,
      provisioningProfiles: { "com.bnjdpn.petitesgouttes" => lane_context[SharedValues::SIGH_NAME] }
    }
  )
end

platform :ios do
  desc "Run all unit tests"
  lane :test do
    run_tests(scheme: "PetitesGouttes", devices: ["iPhone 17 Pro"], clean: false, code_coverage: true)
  end

  desc "Generate new localized screenshots"
  lane :screenshots do
    capture_screenshots(scheme: "PetitesGouttes")
  end

  desc "Push a new beta build to TestFlight"
  lane :beta do
    api_key = load_api_key
    setup_signing(api_key)
    increment_build_number(build_number: latest_testflight_build_number(api_key: api_key) + 1, xcodeproj: "PetitesGouttes.xcodeproj")
    build_signed_app
    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: true)
  end

  desc "Full App Store release: screenshots + metadata + build"
  lane :release do
    api_key = load_api_key
    capture_screenshots(scheme: "PetitesGouttes")
    setup_signing(api_key)
    increment_build_number(build_number: latest_testflight_build_number(api_key: api_key) + 1, xcodeproj: "PetitesGouttes.xcodeproj")
    build_signed_app
    upload_to_app_store(api_key: api_key, skip_binary_upload: true, skip_metadata: true, overwrite_screenshots: true, force: true, run_precheck_before_submit: false, screenshots_path: File.expand_path("../app_store_screenshots", __dir__))
    upload_to_app_store(api_key: api_key, skip_screenshots: true, skip_metadata: false, force: true, run_precheck_before_submit: false)
  end

  desc "Deploy without screenshots"
  lane :release_quick do
    api_key = load_api_key
    setup_signing(api_key)
    increment_build_number(build_number: latest_testflight_build_number(api_key: api_key) + 1, xcodeproj: "PetitesGouttes.xcodeproj")
    build_signed_app
    upload_to_app_store(api_key: api_key, skip_screenshots: true, skip_metadata: false, force: true, run_precheck_before_submit: false)
  end

  desc "Upload metadata only"
  lane :metadata do
    api_key = load_api_key
    upload_to_app_store(api_key: api_key, skip_binary_upload: true, skip_screenshots: true, force: true, run_precheck_before_submit: false)
  end

  desc "Upload screenshots"
  lane :upload_screenshots do
    api_key = load_api_key
    upload_to_app_store(api_key: api_key, skip_binary_upload: true, skip_metadata: true, overwrite_screenshots: true, force: true, run_precheck_before_submit: false, screenshots_path: File.expand_path("../app_store_screenshots", __dir__))
  end
end
